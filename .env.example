# ──────────────────────────────────────────────────────────────
# OSSPREY — Environment Configuration
# Copy this file to .env and fill in your real values.
# See TESTING_INSTRUCTIONS.md → "GitHub Tokens" for details.
# ──────────────────────────────────────────────────────────────

# GitHub tokens for the scraper (read-only access to public repos).
# You only need ONE token — duplicate it across all 4 slots.
# Multiple unique tokens enable rate-limit rotation (5,000 req/hr each).
#
# Get a token via:
#   - `gh auth token`  (if you use GitHub CLI — easiest)
#   - https://github.com/settings/tokens?type=beta  (fine-grained PAT)
#   - https://github.com/settings/tokens  (classic PAT with public_repo scope)
GITHUB_TOKEN_1=ghp_REPLACE_ME
GITHUB_TOKEN_2=ghp_REPLACE_ME
GITHUB_TOKEN_3=ghp_REPLACE_ME
GITHUB_TOKEN_4=ghp_REPLACE_ME

# GitHub username (used by the scraper)
GITHUB_USERNAME=YOUR_GITHUB_USERNAME

# MongoDB connection — uses the Docker internal network hostname "mongodb"
MONGODB_URI=mongodb://ossprey:ossprey_dev_pw@mongodb:27017/decal-db?authSource=admin&retryWrites=true&w=majority

# MongoDB root credentials (used to bootstrap the container)
MONGO_INITDB_ROOT_USERNAME=ossprey
MONGO_INITDB_ROOT_PASSWORD=ossprey_dev_pw
MONGO_INITDB_DATABASE=decal-db

# JWT secret for the Flask backend
JWT_SECRET_KEY=change-me-to-a-real-secret

# Frontend API base URL — port 5001 avoids macOS AirPlay Receiver on port 5000.
# If you disable AirPlay Receiver, you can change this back to 5000.
VITE_API_BASE_URL=http://localhost:5001
